# ── Reels Analytics Dashboard — приклад конфігурації ──
# Скопіюй цей файл у .env і впиши свої значення:  cp .env.example .env

# (Обов'язково) Instagram Graph API токен.
# Тип: «Instagram API with Instagram Login». Зазвичай починається з IGAA...
# Як отримати — див. README, розділ «Як отримати Instagram-токен».
INSTAGRAM_TOKEN=

# (Опційно) Ключ Anthropic (Claude) для ШІ-генерації скриптів і розбору каруселей.
# Без нього вся СТАТИСТИКА працює; вимикається лише ШІ-генерація.
# Створюється на https://console.anthropic.com → API Keys (платний, окремо від claude.ai).
ANTHROPIC_API_KEY=

# (Опційно) Модель розшифровки голосу faster-whisper: tiny | base | small | medium | large-v3
# Більша модель = точніше, але повільніше. Типово: base.
WHISPER_MODEL=base

# (Опційно) Мова розшифровки (ISO-код). Типово: uk (українська).
WHISPER_LANGUAGE=uk

# (Опційно) Підпис автора у футері — Instagram-нік без «@».
# Стає активним посиланням «Створено @нік». Типово: hlyboki_sensy.
CREDIT_HANDLE=hlyboki_sensy
